# Vite: set to "true" to send /api/billing to the local Node server (use with npm run server and real Adyen keys)
VITE_USE_BILLING_API=false

# Billing server (server/index.mjs)
# PORT=3001
# FRONTEND_ORIGIN=http://localhost:5173
# ADYEN_API_KEY=
# ADYEN_CLIENT_KEY=
# ADYEN_MERCHANT_ACCOUNT=
# ADYEN_HMAC_KEY=
# BILLING_DEBUG=1
# ADYEN_CHECKOUT_HOST=https://checkout-test.adyen.com
